# nDrama Subscriber API — Production Environment
# Copy to .env.subscriber.production and fill in real values

# Application
APP_NAME=nDrama Subscriber API
DEBUG=false

# Database (shared with admin backend)
DATABASE_URL=postgresql+asyncpg://ndrama:CHANGE_ME@postgres:5432/ndrama

# Redis
REDIS_URL=redis://:CHANGE_ME@redis:6379/0

# Session
SESSION_TTL_DAYS=90

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# S3 / Linode Object Storage
S3_ENDPOINT=https://eu-central-1.linodeobjects.com
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET=ndrama
