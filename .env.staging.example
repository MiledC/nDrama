# nDrama Backend — Staging Environment
# Copy to .env.staging and fill in real values

# Application
APP_NAME=nDrama API
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://ndrama:CHANGE_ME@postgres:5432/ndrama
POSTGRES_USER=ndrama
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=ndrama

# Redis
REDIS_PASSWORD=CHANGE_ME

# Auth / JWT
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://admin-api.yourdomain.com/api/auth/google/callback

# S3 / Linode Object Storage (no MinIO in production)
S3_ENDPOINT=https://eu-central-1.linodeobjects.com
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET=ndrama

# Video Provider (Mux)
VIDEO_PROVIDER=mux
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Frontend URL (comma-separated for CORS)
FRONTEND_URL=https://admin.yourdomain.com
